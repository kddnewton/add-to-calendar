    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
