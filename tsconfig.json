{
  "compilerOptions": {
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "sourceMap": false,
    "strict": true,
    "target": "es6"
  },
  "include": ["src"],
  "exclude": ["**/__tests__/*"]
}
